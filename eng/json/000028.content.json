"content": "<style>\nh1.thlex-title { font-size: 1.3em; margin: 0 0 0.4em; }\n.thlex-key { color: #888; font-size: 0.85em; font-weight: normal; margin-right: 0.4em; }\nnav.thlex-index { margin: 0.5em 0 0.75em; }\nnav.thlex-index ul { margin: 0; padding-left: 1.2em; }\nnav.thlex-index li { margin: 0.15em 0; font-size: 0.95em; }\n.thlex-section { margin: 0.6em 0; }\nh2.thlex-heading { font-size: 1em; margin: 0.5em 0 0.2em; }\nh3.thlex-subheading { font-size: 0.95em; font-weight: normal; font-style: italic; margin: 0.2em 0; }\n.thlex-language-sets { margin: 0.3em 0 0.3em 1em; }\n.thlex-language-set { margin: 0.4em 0; padding-left: 0.75em; border-left: 3px solid #e0e0e0; }\n.thlex-language { font-size: 0.8em; color: #888; margin-right: 0.4em; }\n.thlex-lemma { font-weight: bold; font-family: serif; }\n.thlex-translit { color: #555; font-style: italic; font-size: 0.9em; margin-left: 0.3em; }\n.thlex-refs { font-size: 0.85em; color: #444; margin-top: 0.15em; }\n.thlex-paragraphs p { margin: 0.35em 0; font-size: 0.95em; line-height: 1.5; }\n.thlex-image { margin: 0.5em 0; }\n.thlex-image img { max-width: 100%; height: auto; }\n.thlex-abbr { border-bottom: 1px dotted #888; cursor: help; }\n.thlex-xref { color: #1a5fb4; }\nspan[data-bnType=\"bibleReference\"] { color: #1a5fb4; }\ntable.thlex-table { border-collapse: collapse; font-size: 0.9em; margin: 0.5em 0; }\ntable.thlex-table td { padding: 0.2em 0.6em; vertical-align: top; border: 1px solid #ddd; }\ntable.thlex-table tr:first-child td { font-weight: bold; background: #f5f5f5; }\nul.thlex-index-list { margin: 0.4em 0; padding-left: 1.4em; font-size: 0.95em; line-height: 1.6; }\nul.thlex-index-list ul { margin: 0.1em 0; padding-left: 1.4em; }\n.thlex-index-key { font-weight: bold; font-style: italic; }\n</style><h1 class=\"thlex-title\" id=\"FAUNA:2.18\"><span class=\"thlex-key\">2.18</span> Horse</h1><div class=\"thlex-section\">\n<h2 class=\"thlex-heading\">References:</h2>\n<div class=\"thlex-language-sets\">\n<div class=\"thlex-language-set\">\n<span class=\"thlex-language\">Hebrew</span> <span class=\"thlex-lemma\">סוּס, סוּסָה</span> <span class=\"thlex-translit\">(sus, susah)</span>\n<div class=\"thlex-refs\"><a href=\"https://ref.ly/Gen47:17\">GEN 47:17</a>, <a href=\"https://ref.ly/Gen49:17\">GEN 49:17</a>, <a href=\"https://ref.ly/Exod9:3\">EXO 9:3</a>, <a href=\"https://ref.ly/Exod14:9\">EXO 14:9</a>, <a href=\"https://ref.ly/Exod14:23\">EXO 14:23</a>, <a href=\"https://ref.ly/Exod15:1\">EXO 15:1</a>, <a href=\"https://ref.ly/Exod15:19\">EXO 15:19</a>, <a href=\"https://ref.ly/Exod15:21\">EXO 15:21</a>, <a href=\"https://ref.ly/Deut11:4\">DEU 11:4</a>, <a href=\"https://ref.ly/Deut17:16\">DEU 17:16</a>, <a href=\"https://ref.ly/Deut20:1\">DEU 20:1</a>, <a href=\"https://ref.ly/Josh11:4\">JOS 11:4</a>, <a href=\"https://ref.ly/Josh11:6\">JOS 11:6</a>, <a href=\"https://ref.ly/Josh11:9\">JOS 11:9</a>, <a href=\"https://ref.ly/Judg5:22\">JDG 5:22</a>, <a href=\"https://ref.ly/2Sam15:1\">2SA 15:1</a>, <a href=\"https://ref.ly/1Kgs5:6\">1KI 5:6</a>, <a href=\"https://ref.ly/1Kgs5:8\">1KI 5:8</a>, <a href=\"https://ref.ly/1Kgs10:25\">1KI 10:25</a>, <a href=\"https://ref.ly/1Kgs10:28\">1KI 10:28</a>, <a href=\"https://ref.ly/1Kgs10:29\">1KI 10:29</a>, <a href=\"https://ref.ly/1Kgs18:5\">1KI 18:5</a>, <a href=\"https://ref.ly/1Kgs20:1\">1KI 20:1</a>, <a href=\"https://ref.ly/1Kgs20:20\">1KI 20:20</a>, <a href=\"https://ref.ly/1Kgs20:21\">1KI 20:21</a>, <a href=\"https://ref.ly/1Kgs20:25\">1KI 20:25</a>, <a href=\"https://ref.ly/1Kgs22:4\">1KI 22:4</a>, <a href=\"https://ref.ly/2Kgs2:11\">2KI 2:11</a>, <a href=\"https://ref.ly/2Kgs3:7\">2KI 3:7</a>, <a href=\"https://ref.ly/2Kgs5:9\">2KI 5:9</a>, <a href=\"https://ref.ly/2Kgs6:14\">2KI 6:14</a>, <a href=\"https://ref.ly/2Kgs6:15\">2KI 6:15</a>, <a href=\"https://ref.ly/2Kgs6:17\">2KI 6:17</a>, <a href=\"https://ref.ly/2Kgs7:6\">2KI 7:6</a>, <a href=\"https://ref.ly/2Kgs7:7\">2KI 7:7</a>, <a href=\"https://ref.ly/2Kgs7:10\">2KI 7:1