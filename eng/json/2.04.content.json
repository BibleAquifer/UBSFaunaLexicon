"content": "<style>\nh1.thlex-title { font-size: 1.3em; margin: 0 0 0.4em; }\n.thlex-key { color: #888; font-size: 0.85em; font-weight: normal; margin-right: 0.4em; }\nnav.thlex-index { margin: 0.5em 0 0.75em; }\nnav.thlex-index ul { margin: 0; padding-left: 1.2em; }\nnav.thlex-index li { margin: 0.15em 0; font-size: 0.95em; }\n.thlex-section { margin: 0.6em 0; }\nh2.thlex-heading { font-size: 1em; margin: 0.5em 0 0.2em; }\nh3.thlex-subheading { font-size: 0.95em; font-weight: normal; font-style: italic; margin: 0.2em 0; }\n.thlex-language-sets { margin: 0.3em 0 0.3em 1em; }\n.thlex-language-set { margin: 0.4em 0; padding-left: 0.75em; border-left: 3px solid #e0e0e0; }\n.thlex-language { font-size: 0.8em; color: #888; margin-right: 0.4em; }\n.thlex-lemma { font-weight: bold; font-family: serif; }\n.thlex-translit { color: #555; font-style: italic; font-size: 0.9em; margin-left: 0.3em; }\n.thlex-refs { font-size: 0.85em; color: #444; margin-top: 0.15em; }\n.thlex-paragraphs p { margin: 0.35em 0; font-size: 0.95em; line-height: 1.5; }\n.thlex-image { margin: 0.5em 0; }\n.thlex-image img { max-width: 100%; height: auto; }\n.thlex-abbr { border-bottom: 1px dotted #888; cursor: help; }\n.thlex-xref { color: #1a5fb4; }\nspan[data-bnType=\"bibleReference\"] { color: #1a5fb4; }\ntable.thlex-table { border-collapse: collapse; font-size: 0.9em; margin: 0.5em 0; }\ntable.thlex-table td { padding: 0.2em 0.6em; vertical-align: top; border: 1px solid #ddd; }\ntable.thlex-table tr:first-child td { font-weight: bold; background: #f5f5f5; }\nul.thlex-index-list { margin: 0.4em 0; padding-left: 1.4em; font-size: 0.95em; line-height: 1.6; }\nul.thlex-index-list ul { margin: 0.1em 0; padding-left: 1.4em; }\n.thlex-index-key { font-weight: bold; font-style: italic; }\n</style><h1 class=\"thlex-title\" id=\"FAUNA:2.4\"><span class=\"thlex-key\">2.4</span> Ass, donkey</h1><div class=\"thlex-section\">\n<h2 class=\"thlex-heading\">References:</h2>\n<div class=\"thlex-language-sets\">\n<div class=\"thlex-language-set\">\n<span class=\"thlex-language\">Hebrew</span> <span class=\"thlex-lemma\">אָתוֹן</span> <span class=\"thlex-translit\">(‘athon)</span>\n<div class=\"thlex-refs\"><a href=\"https://ref.ly/Gen12:16\">GEN 12:16</a>, <a href=\"https://ref.ly/Gen32:16\">GEN 32:16</a>, <a href=\"https://ref.ly/Gen45:23\">GEN 45:23</a>, <a href=\"https://ref.ly/Gen49:11\">GEN 49:11</a>, <a href=\"https://ref.ly/Num22:21\">NUM 22:21</a>, <a href=\"https://ref.ly/Num22:22\">NUM 22:22</a>, <a href=\"https://ref.ly/Num22:23\">NUM 22:23</a>, <a href=\"https://ref.ly/Num22:23\">NUM 22:23</a>, <a href=\"https://ref.ly/Num22:23\">NUM 22:23</a>, <a href=\"https://ref.ly/Num22:25\">NUM 22:25</a>, <a href=\"https://ref.ly/Num22:27\">NUM 22:27</a>, <a href=\"https://ref.ly/Num22:27\">NUM 22:27</a>, <a href=\"https://ref.ly/Num22:28\">NUM 22:28</a>, <a href=\"https://ref.ly/Num22:29\">NUM 22:29</a>, <a href=\"https://ref.ly/Num22:30\">NUM 22:30</a>, <a href=\"https://ref.ly/Num22:30\">NUM 22:30</a>, <a href=\"https://ref.ly/Num22:32\">NUM 22:32</a>, <a href=\"https://ref.ly/Num22:33\">NUM 22:33</a>, <a href=\"https://ref.ly/Judg5:10\">JDG 5:10</a>, <a href=\"https://ref.ly/1Sam9:3\">1SA 9:3</a>, <a href=\"https://ref.ly/1Sam9:3\">1SA 9:3</a>, <a href=\"https://ref.ly/1Sam9:5\">1SA 9:5</a>, <a href=\"https://ref.ly/1Sam9:20\">1SA 9:20</a>, <a href=\"https://ref.ly/1Sam10:2\">1SA 10:2</a>, <a href=\"https://ref.ly/1Sam10:2\">1SA 10:2</a>, <a href=\"https://ref.ly/1Sam10:14\">1SA 10:14</a>, <a href=\"https://ref.ly/1Sam10:16\">1SA 10:16</a>, <a href=\"https://ref.ly/2Kgs4:22\">2KI 4:22</a>, <a href=\"https://ref.ly/2Kgs4:24\">2KI 4:24</a>, <a href=\"https://ref.ly/1Chr27:30\">1CH 27:30</a>, <a href=\"https://ref.ly/Job1:3\">JOB 1:3</a>, <a href=\"https://ref.ly/Job1:14\">JOB 1:14</a>, <a href=\"https://ref.ly/Job42:12\">JOB 42:12</a>, <a href=\"https://ref.ly/Zech9:9\">ZEC 9:9</a></div>\n</div>\n<div class=\"thlex-language-set\">\n<span class=\"thlex-language\">Hebrew</span>