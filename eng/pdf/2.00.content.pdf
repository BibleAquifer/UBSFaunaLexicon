5 beginbfchar
<0001> <004D>
<0002> <0061>
<0003> <006D>
<0004> <006C>
<0005> <0073>
endbfchar
endcmap
CMapName currentdict /CMap defineresource pop
end
end
%%EndResource
%%EOF
endstream
endobj

