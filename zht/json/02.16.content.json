"content": "<style>\nh1.thlex-title { font-size: 1.3em; margin: 0 0 0.4em; }\n.thlex-key { color: #888; font-size: 0.85em; font-weight: normal; margin-right: 0.4em; }\nnav.thlex-index { margin: 0.5em 0 0.75em; }\nnav.thlex-index ul { margin: 0; padding-left: 1.2em; }\nnav.thlex-index li { margin: 0.15em 0; font-size: 0.95em; }\n.thlex-section { margin: 0.6em 0; }\nh2.thlex-heading { font-size: 1em; margin: 0.5em 0 0.2em; }\nh3.thlex-subheading { font-size: 0.95em; font-weight: normal; font-style: italic; margin: 0.2em 0; }\n.thlex-language-sets { margin: 0.3em 0 0.3em 1em; }\n.thlex-language-set { margin: 0.4em 0; padding-left: 0.75em; border-left: 3px solid #e0e0e0; }\n.thlex-language { font-size: 0.8em; color: #888; margin-right: 0.4em; }\n.thlex-lemma { font-weight: bold; font-family: serif; }\n.thlex-translit { color: #555; font-style: italic; font-size: 0.9em; margin-left: 0.3em; }\n.thlex-refs { font-size: 0.85em; color: #444; margin-top: 0.15em; }\n.thlex-paragraphs p { margin: 0.35em 0; font-size: 0.95em; line-height: 1.5; }\n.thlex-image { margin: 0.5em 0; }\n.thlex-image img { max-width: 100%; height: auto; }\n.thlex-abbr { border-bottom: 1px dotted #888; cursor: help; }\n.thlex-xref { color: #1a5fb4; }\nspan[data-bnType=\"bibleReference\"] { color: #1a5fb4; }\ntable.thlex-table { border-collapse: collapse; font-size: 0.9em; margin: 0.5em 0; }\ntable.thlex-table td { padding: 0.2em 0.6em; vertical-align: top; border: 1px solid #ddd; }\ntable.thlex-table tr:first-child td { font-weight: bold; background: #f5f5f5; }\nul.thlex-index-list { margin: 0.4em 0; padding-left: 1.4em; font-size: 0.95em; line-height: 1.6; }\nul.thlex-index-list ul { margin: 0.1em 0; padding-left: 1.4em; }\n.thlex-index-key { font-weight: bold; font-style: italic; }\n</style><h1 class=\"thlex-title\" id=\"FAUNA:2.16\"><span class=\"thlex-key\">2.16</span> 標題：山羊（goat）</h1><div class=\"thlex-section\">\n<h2 class=\"thlex-heading\">經文出處</h2>\n<div class=\"thlex-language-sets\">\n<div class=\"thlex-language-set\">\n<span class=\"thlex-language\">Hebrew</span> <span class=\"thlex-lemma\">來：עֵז</span> <span class=\"thlex-translit\">(音譯：‘ez)</span>\n<div class=\"thlex-refs\"><a href=\"https://ref.ly/Gen15:9\">GEN 15:9</a>, <a href=\"https://ref.ly/Gen27:9\">GEN 27:9</a>, <a href=\"https://ref.ly/Gen27:16\">GEN 27:16</a>, <a href=\"https://ref.ly/Gen30:32\">GEN 30:32</a>, <a href=\"https://ref.ly/Gen30:33\">GEN 30:33</a>, <a href=\"https://ref.ly/Gen30:35\">GEN 30:35</a>, <a href=\"https://ref.ly/Gen31:38\">GEN 31:38</a>, <a href=\"https://ref.ly/Gen32:15\">GEN 32:15</a>, <a href=\"https://ref.ly/Gen37:31\">GEN 37:31</a>, <a href=\"https://ref.ly/Gen38:17\">GEN 38:17</a>, <a href=\"https://ref.ly/Gen38:20\">GEN 38:20</a>, <a href=\"https://ref.ly/Exod12:5\">EXO 12:5</a>, <a href=\"https://ref.ly/Lev1:10\">LEV 1:10</a>, <a href=\"https://ref.ly/Lev3:12\">LEV 3:12</a>, <a href=\"https://ref.ly/Lev4:23\">LEV 4:23</a>, <a href=\"https://ref.ly/Lev4:28\">LEV 4:28</a>, <a href=\"https://ref.ly/Lev5:6\">LEV 5:6</a>, <a href=\"https://ref.ly/Lev7:23\">LEV 7:23</a>, <a href=\"https://ref.ly/Lev9:3\">LEV 9:3</a>, <a href=\"https://ref.ly/Lev16:5\">LEV 16:5</a>, <a href=\"https://ref.ly/Lev17:3\">LEV 17:3</a>, <a href=\"https://ref.ly/Lev22:19\">LEV 22:19</a>, <a href=\"https://ref.ly/Lev22:27\">LEV 22:27</a>, <a href=\"https://ref.ly/Lev23:19\">LEV 23:19</a>, <a href=\"https://ref.ly/Num7:16\">NUM 7:16</a>, <a href=\"https://ref.ly/Num7:22\">NUM 7:22</a>, <a href=\"https://ref.ly/Num7:28\">NUM 7:28</a>, <a href=\"https://ref.ly/Num7:34\">NUM 7:34</a>, <a href=\"https://ref.ly/Num7:40\">NUM 7:40</a>, <a href=\"https://ref.ly/Num7:46\">NUM 7:46</a>, <a href=\"https://ref.ly/Num7:52\">NUM 7:52</a>, <a href=\"https://ref.ly/Num7:58\">NUM 7:58</a>, <a href=\"https://ref.ly/Num7:64\">NUM 7:64</a>, <a href=\"https://ref.ly/Num7:70\">NUM 7:70</a>, <a href=\"https://ref.ly/Num7:76\">NUM 7:76</a>, <a href=\"https://ref.ly/Num7:82\">NUM 7:82</a>, <a href=\"https://ref.ly/Num